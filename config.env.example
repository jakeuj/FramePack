# FramePack 用戶配置文件
# 複製此文件為 config.env 並修改以下設定

# =============================================================================
# 服務配置
# =============================================================================

# 認證設定
USERNAME=admin
PASSWORD=123456

# 端口設定
DEFAULT_PORT=7860
SECOND_PORT=7861

# 服務器監聽地址
# 0.0.0.0 = 允許外部訪問
# 127.0.0.1 = 僅本機訪問
HOST=0.0.0.0

# =============================================================================
# Python 環境配置
# =============================================================================

# 本地虛擬環境路徑 (留空使用默認 .venv)
# 例如: /path/to/your/venv 或 /home/user/.virtualenvs/FramePackB
LOCAL_VENV_PATH=

# 本地 Python 解釋器路徑 (留空自動從虛擬環境推導)
# 例如: /home/user/.virtualenvs/FramePackB/bin/python
LOCAL_PYTHON=

# =============================================================================
# 遠端開發配置
# =============================================================================

# 是否啟用遠端模式 (true/false)
ENABLE_REMOTE=false

# 遠端服務器設定
REMOTE_HOST=192.168.1.104
REMOTE_USER=jake

# 遠端 Python 環境路徑
REMOTE_PYTHON=/home/jake/.virtualenvs/FramePackB/bin/python

# 遠端項目目錄
REMOTE_PROJECT_DIR=/tmp/pycharm_project_662

# =============================================================================
# 高級配置
# =============================================================================

# 強制外部訪問 (當 HOST=0.0.0.0 時在 macOS 上也允許外部訪問)
FORCE_EXTERNAL_ACCESS=false

# GPU 設備配置 (留空自動檢測)
# 例如: 0,1,2,3
CUDA_VISIBLE_DEVICES=

# 第二個 GPU 服務 (true/false，留空自動檢測)
ENABLE_SECOND_GPU=

# =============================================================================
# 使用說明
# =============================================================================

# 1. 複製此文件為 config.env:
#    cp config.env.example config.env
#
# 2. 根據你的環境修改配置值
#
# 3. 本地開發環境配置:
#    - 設置 ENABLE_REMOTE=false
#    - 配置 LOCAL_VENV_PATH 或 LOCAL_PYTHON (可選，留空使用默認)
#    - 其他設置保持默認
#
# 4. 遠端開發環境配置:
#    - 設置 ENABLE_REMOTE=true
#    - 配置 REMOTE_HOST, REMOTE_USER, REMOTE_PYTHON, REMOTE_PROJECT_DIR
#    - 確保 SSH 免密登錄已設置
#
# 5. Python 環境配置範例:
#    # 使用自定義虛擬環境
#    LOCAL_VENV_PATH=/home/user/.virtualenvs/FramePackB
#
#    # 或直接指定 Python 解釋器
#    LOCAL_PYTHON=/home/user/.virtualenvs/FramePackB/bin/python
#
# 6. 安全提醒:
#    - config.env 文件包含敏感信息，已加入 .gitignore
#    - 不要將 config.env 提交到版本控制系統
#    - 定期更改密碼以確保安全
