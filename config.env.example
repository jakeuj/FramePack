# FramePack 用戶配置文件
# 複製此文件為 config.env 並修改以下設定

# =============================================================================
# 服務配置
# =============================================================================

# 認證設定
USERNAME=admin
PASSWORD=123456

# 端口設定
DEFAULT_PORT=7860
SECOND_PORT=7861

# 服務器監聽地址
# 0.0.0.0 = 允許外部訪問
# 127.0.0.1 = 僅本機訪問
HOST=0.0.0.0

# =============================================================================
# 遠端開發配置
# =============================================================================

# 是否啟用遠端模式 (true/false)
ENABLE_REMOTE=false

# 遠端服務器設定
REMOTE_HOST=192.168.1.104
REMOTE_USER=jake

# 遠端 Python 環境路徑
REMOTE_PYTHON=/home/jake/.virtualenvs/FramePackB/bin/python

# 遠端項目目錄
REMOTE_PROJECT_DIR=/tmp/pycharm_project_662

# =============================================================================
# 使用說明
# =============================================================================

# 1. 本地開發模式 (默認):
#    ENABLE_REMOTE=false
#    使用本地 Python 環境和 GPU

# 2. 遠端開發模式:
#    ENABLE_REMOTE=true
#    通過 SSH 連接到遠端服務器執行
#    需要確保 SSH 免密登錄已設置

# 3. 修改認證信息:
#    USERNAME=your_username
#    PASSWORD=your_password

# 4. 修改端口:
#    DEFAULT_PORT=8080
#    SECOND_PORT=8081

# 5. 限制本機訪問:
#    HOST=127.0.0.1
